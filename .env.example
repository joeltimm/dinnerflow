# Iron Skillet — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DINNER_DB_NAME=dinnerflow
DINNER_DB_USER=dinneruser
DINNER_DB_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────────────────
# Fernet key for encrypting Todoist API tokens in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Secret key for signing 'Add to My Recipes' links in meal plan emails.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── LLM (local OpenAI-compatible endpoint) ────────────────────────────────────
# Point at your local LLM server (LM Studio, Ollama openai-compat, etc.)
LLM_BASE_URL=http://your-llm-host:8081/v1
LLM_MODEL=gpt-4o-mini

# ── Tavily (web search for recipe ideas) ──────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ── Gmail (replaces n8n email sending — mirrors ~/calendar_bot pattern) ───────
# Full Gmail address used to send emails
SENDER_EMAIL=joeltimm@gmail.com

# ── Host paths (mounted into containers by compose.yml) ──────────────────────
# Directory containing token_{suffix}.json files for Gmail OAuth.
# Mounted read-only. The token auto-refreshes at runtime.
GOOGLE_AUTH_HOST_PATH=/path/to/google_auth

# Directory for recipe image uploads (persisted on host).
# Defaults to ./uploads if not set.
# UPLOADS_HOST_PATH=./uploads

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
# Used by Celery for background tasks (email, meal plans, session cleanup).
# The compose.yml sets this automatically; override here only for non-Docker dev.
# REDIS_URL=redis://redis:6379/0

# ── Database pool ─────────────────────────────────────────────────────────────
# Max DB connections in the pool (default 50). Increase if running many workers.
# DB_POOL_MAX=50

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL — used to build clickable links in emails
APP_BASE_URL=https://ironskillet.joeltimm.dev

# CORS: space-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost http://localhost:5173 https://ironskillet.joeltimm.dev
